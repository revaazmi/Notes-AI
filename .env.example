# Neon Postgres (dapat URL dari Vercel Storage → Postgres, atau dashboard Neon)
DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Groq API Key (dapat dari https://console.groq.com/keys)
GROQ_API_KEY="gsk_your_api_key_here"

# NextAuth v5 — generate dengan: npx auth secret
AUTH_SECRET="your_auth_secret_here"

# SMTP (email via Gmail) — App Password dari Google Account → Security → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER="your.email@gmail.com"
SMTP_PASS="xxxx xxxx xxxx xxxx"
EMAIL_FROM="Littera <your.email@gmail.com>"

# Base URL aplikasi (berubah di production)
APP_URL="http://localhost:3000"

# Secret untuk cron cleanup (isi string random)
CRON_SECRET="your-cron-secret-here"
